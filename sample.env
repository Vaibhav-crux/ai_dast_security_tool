# OWASP ZAP Configuration (Configure these to match your running ZAP instance)
ZAP_API_KEY=changeme123  # Get this from ZAP UI: Tools -> Options -> API
ZAP_PORT=8080           # Default ZAP port
ZAP_API_URL=http://localhost:8080

# AI Model Configuration
AI_MODEL_PATH=models/q4_0-orca-mini-3b.gguf
AI_MODEL_THREADS=4
AI_MODEL_CONTEXT_SIZE=2048
AI_MODEL_TEMPERATURE=0.7

# Output Directories
SCAN_RESULTS_DIR=scan_results
REPORT_DIR=reports
LOG_DIR=logs
CACHE_DIR=models/cache

# Scanning Configuration
MAX_SCAN_DURATION=3600
MAX_SPIDER_DURATION=1800
SCAN_RECURSION_DEPTH=10
SCAN_THREAD_COUNT=4

# Debug Settings
DEBUG=false
VERBOSE_LOGGING=true
LOG_LEVEL=INFO

# Note: Copy this file to .env and update the values as needed 